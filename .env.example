# ====================================================================
# Configuración del Bot de Escrow de Criptomonedas
# Duplica este archivo como '.env' y completa los valores requeridos.
# ====================================================================

# 🤖 DISCORD BOT CONFIGURATION
# Obtén tu token en: https://discord.com/developers/applications
DISCORD_TOKEN=tu_discord_bot_token_aqui

# 📋 LOGGING & AUDIT
# ID del canal de Discord donde se enviarán todos los registros/logs del escrow
LOG_CHANNEL_ID=123456789012345678

# 🔐 SECURITY & WALLET GENERATION
# Clave/Semilla maestra para la derivación segura y encriptación de las private keys de cada escrow.
# Puedes generar una clave aleatoria en tu consola de python usando:
# >>> from cryptography.fernet import Fernet
# >>> print(Fernet.generate_key().decode())
WALLET_MASTER_KEY=tu_clave_maestra_fernet_aqui

# ====================================================================
# BLOCKCHAIN CONNECTIONS (APIs & Endpoints)
# ====================================================================

# 💎 ETHEREUM (ETH) & ERC-20 (USDT / USDC)
# Regístrate en https://infura.io para obtener una URL gratuita
INFURA_URL=https://mainnet.infura.io/v3/tu_infura_project_id

# ☀️ SOLANA (SOL)
# Endpoint RPC de Solana (puedes usar el público por defecto o uno premium como QuickNode/Helius)
SOLANA_RPC=https://api.mainnet-beta.solana.com

# 🪙 BITCOIN (BTC) & LITECOIN (LTC)
# El bot utiliza BlockCypher para enviar y escanear transacciones de BTC/LTC.
# Regístrate en https://accounts.blockcypher.com/ para obtener un token gratuito.
BLOCKCYPHER_TOKEN=tu_token_de_blockcypher_aqui
